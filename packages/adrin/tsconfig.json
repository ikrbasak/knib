{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "types": ["node"],
    "lib": ["ES2023"]
  },
  "include": ["src"]
}
